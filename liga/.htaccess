# Liga Deportiva - Apache config

# Output buffering: evita "headers already sent" por BOM en archivos PHP
# (funciona cuando PHP corre como módulo de Apache)
<IfModule mod_php.c>
    php_value output_buffering 4096
</IfModule>
<IfModule mod_php8.c>
    php_value output_buffering 4096
</IfModule>
<IfModule mod_php7.c>
    php_value output_buffering 4096
</IfModule>
